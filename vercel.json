{
  "version": 2,
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "npm install",
  "outputDirectory": "frontend/build",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://stockoptimizer-api.onrender.com/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
