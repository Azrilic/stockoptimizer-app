{
  "name": "stockoptimizer-detektiv",
  "version": "1.0.0",
  "homepage": "https://azrilic.github.io/stockoptimizer-app",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "gh-pages": "^6.1.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "prebuild": "mkdir -p public && printf '%s' '<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"utf-8\" /><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" /><title>StockOptimizer Detektiv</title></head><body><div id=\"root\"></div></body></html>' > public/index.html",
    "build": "react-scripts build",
    "deploy": "npm run build && gh-pages -d build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
